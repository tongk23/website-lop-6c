rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // ===============================================================
    // Assumed Data Model
    // ===============================================================
    //
    // Collection: users
    // Document ID: {userId} (matches Firebase Auth UID)
    // Fields:
    //   - fullName: string (required) - User's full name
    //   - role: string (required, 'student' | 'teacher') - User's role
    //   - grade: string (optional) - User's grade (for students)
    //   - email: string (required) - User's email
    //   - uid: string (required) - User's unique ID
    //
    // ===============================================================

    // ===============================================================
    // Helper Functions
    // ===============================================================
    function isAuthenticated() {
      return request.auth != null;
    }
    
    function isOwner(userId) {
      return isAuthenticated() && request.auth.uid == userId;
    }
    
    function isValidUser(data) {
      return data.keys().hasAll(['fullName', 'role', 'email', 'uid']) &&
             data.fullName is string && data.fullName.size() > 0 && data.fullName.size() < 100 &&
             data.role in ['student', 'teacher'] &&
             data.email is string && data.email.size() > 0 &&
             data.uid == request.auth.uid &&
             (!('grade' in data) || (data.grade is string && data.grade.size() > 0 && data.grade.size() < 10));
    }

    match /users/{userId} {
      allow read: if isOwner(userId);
      allow create: if isOwner(userId) && isValidUser(request.resource.data);
      allow update: if isOwner(userId) && isValidUser(request.resource.data) && 
                      request.resource.data.role == resource.data.role; // Role cannot be changed by user
    }

    function isValidPost(data) {
      return data.keys().hasAll(['author', 'authorUid', 'role', 'content', 'timestamp', 'likes']) &&
             data.author is string && data.author.size() > 0 && data.author.size() < 100 &&
             data.authorUid == request.auth.uid &&
             data.role in ['student', 'teacher'] &&
             data.content is string && data.content.size() < 5000 &&
             data.likes is number && data.likes >= 0 &&
             (!('isMemory' in data) || data.isMemory is bool) &&
             (!('isReported' in data) || data.isReported is bool);
    }

    match /posts/{postId} {
      allow read: if isAuthenticated();
      allow create: if isAuthenticated() && isValidPost(request.resource.data);
      allow update: if isAuthenticated() && (
        // Owner can update content
        (request.auth.uid == resource.data.authorUid && isValidPost(request.resource.data) && 
         request.resource.data.authorUid == resource.data.authorUid) ||
        // Anyone can like (increment likes by 1)
        (request.resource.data.diff(resource.data).affectedKeys().hasOnly(['likes']) &&
         request.resource.data.likes == resource.data.likes + 1) ||
        // Teacher can report or delete
        (get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'teacher')
      );
      allow delete: if isAuthenticated() && (
        request.auth.uid == resource.data.authorUid ||
        get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'teacher'
      );
    }
  }
}
